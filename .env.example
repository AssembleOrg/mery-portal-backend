# Database
DATABASE_URL="postgresql://username:password@localhost:5432/mery_portal?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="24h"

# Application
PORT=3000
NODE_ENV="development"

# Swagger
SWAGGER_ENABLED=true
SWAGGER_PASSWORD="admin123"

# CORS
CORS_ORIGIN="http://localhost:3000"

# Brevo (Email Service)
BREVO_API_KEY="your-brevo-api-key"
EMAIL_FROM="noreply@merygarcia.com"
FRONTEND_URL="http://localhost:3000"

# Vimeo Integration
VIMEO_CLIENT_ID="your-vimeo-client-id"
VIMEO_CLIENT_SECRET="your-vimeo-client-secret"
VIMEO_ACCESS_TOKEN="your-vimeo-access-token"

# Problem reports via Pistech WhatsApp API
PISTECH_WHATSAPP_API_URL=""
PISTECH_WHATSAPP_API_KEY=""
PISTECH_WHATSAPP_GROUP_JID=""
PROBLEM_REPORT_APP_NAME="Frontend Web Mery"

# DigitalOcean Spaces (storage para imágenes del chat)
# Endpoint debe incluir protocolo: https://nyc3.digitaloceanspaces.com
DO_SPACES_ENDPOINT=""
DO_SPACES_REGION="us-east-1"
DO_SPACES_BUCKET=""
DO_SPACES_KEY=""
DO_SPACES_SECRET=""
# Opcional: URL base del CDN (si tenés uno configurado), ej. https://cdn.merygarcia.com
# Si queda vacío se usa el endpoint público del bucket.
DO_SPACES_CDN_URL=""
